---
import { sanityClient } from "sanity:client";
import imageUrlBuilder from "@sanity/image-url";

const { settings } = Astro.props;
const builder = imageUrlBuilder(sanityClient);
const urlFor = (source: any) => builder.image(source);

const navBgStart = settings?.navbarBg?.hex || 'transparent';
const navBgEnd = settings?.navbarBgEnd?.hex;
const navOpacity = (settings?.navbarOpacity ?? 95) / 100;
const navTextHex = settings?.navbarText?.hex || 'var(--brand-text)';
const navHoverHex = settings?.brandSecondary?.hex || 'var(--brand-primary)';

const navBackground = navBgEnd 
  ? `linear-gradient(180deg, ${navBgStart}, ${navBgEnd})` 
  : navBgStart;
---

<nav 
  class="sticky top-0 z-[100] w-full px-6 md:px-12 border-b border-white/5 backdrop-blur-xl transition-all duration-300"
  style={`background: ${navBackground}; opacity: ${navOpacity}; --nav-hover: ${navHoverHex}; --nav-text: ${navTextHex};`}
>
  <div class="max-w-7xl mx-auto w-full flex justify-between items-center" style="height: var(--nav-height);">
    {/* Logo / Title Area */}
    <a href="/" class="flex-shrink-0 font-black text-2xl tracking-tighter font-[family-name:var(--font-heading)] transition-transform hover:scale-105" style="color: var(--nav-text);">
      {settings?.logo ? 
        <img src={urlFor(settings.logo).height(120).auto('format').url()} alt={settings.title} class="h-12 w-auto object-contain" /> 
        : <span>{settings?.title}</span>
      }
    </a>

    {/* Desktop Menu - Beefed up size and weight */}
    <ul class="hidden lg:flex gap-12">
      {settings?.navLinks?.map((link: any) => (
        <li>
          <a href={link.url} class="nav-link text-xs font-black uppercase tracking-[0.25em]">
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    {/* Mobile Toggle Button */}
    <button id="menu-toggle" class="lg:hidden p-2" aria-label="Toggle Menu" style="color: var(--nav-text);">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 6h16M4 12h16m-7 6h7" />
      </svg>
    </button>
  </div>

  {/* Mobile Menu - Forced vertical stack and larger text */}
  <div id="mobile-menu" class="hidden absolute left-0 right-0 top-full w-full border-b border-white/10 p-10 flex flex-col gap-8 text-center backdrop-blur-3xl shadow-2xl" style={`background: ${navBackground};`}>
    {settings?.navLinks?.map((link: any) => (
      <a href={link.url} class="nav-link text-xl font-black uppercase tracking-[0.3em] block w-full py-2">
        {link.label}
      </a>
    ))}
  </div>
</nav>

<script>
  const btn = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    menu?.classList.toggle('flex'); // Forces flex-col stack
  });
</script>

<style>
  .nav-link { color: var(--nav-text); transition: all 0.3s ease; opacity: 0.8; }
  .nav-link:hover { color: var(--nav-hover); opacity: 1; transform: translateY(-2px); }
</style>