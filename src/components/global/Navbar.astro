---
import { sanityClient } from "sanity:client";
import imageUrlBuilder from "@sanity/image-url";

const builder = imageUrlBuilder(sanityClient);
const urlFor = (source: any) => builder.image(source);

const settings = await sanityClient.fetch(`
  *[_type == "siteSettings"][0]{
    title, logo, navbarBg{hex}, navbarBgEnd{hex}, navbarOpacity, navbarText{hex}, brandSecondary{hex}, navLinks[]{ label, url }
  }
`);

const navBgStart = settings?.navbarBg?.hex || '#28B579';
const navBgEnd = settings?.navbarBgEnd?.hex;
const navOpacity = (settings?.navbarOpacity ?? 95) / 100;
const navTextHex = settings?.navbarText?.hex || '#593569';
const navHoverHex = settings?.brandSecondary?.hex || '#FF7D00';

const navBackground = navBgEnd 
  ? `linear-gradient(135deg, ${navBgStart}, ${navBgEnd})` 
  : navBgStart;
---

<nav 
  class="sticky top-0 z-[100] w-full px-6 border-b border-white/10 backdrop-blur-md shadow-md"
  style={`background: ${navBackground} !important; opacity: ${navOpacity}; --nav-hover: ${navHoverHex}; --nav-text: ${navTextHex};`}
>
  <div class="max-w-7xl mx-auto w-full flex justify-between items-center" style="height: var(--nav-height);">
    <a href="/" class="flex-shrink-0 font-bold text-2xl tracking-tight font-[family-name:var(--font-heading)]" style="color: var(--nav-text);">
      {settings?.logo ? <img src={urlFor(settings.logo).height(80).url()} alt={settings.title} class="h-10 w-auto" /> : <span>{settings?.title}</span>}
    </a>

    <ul class="hidden md:flex gap-8">
      {settings?.navLinks?.map((link: any) => (
        <li><a href={link.url} class="nav-link text-sm font-bold uppercase tracking-widest">{link.label}</a></li>
      ))}
    </ul>

    <button id="menu-toggle" class="md:hidden p-2" style="color: var(--nav-text);">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden md:hidden absolute left-0 right-0 top-full border-b border-white/10 p-6 flex flex-col space-y-4 text-center shadow-xl" style={`background: ${navBackground};`}>
    {settings?.navLinks?.map((link: any) => (
      <a href={link.url} class="nav-link text-sm font-bold uppercase tracking-widest">{link.label}</a>
    ))}
  </div>
</nav>

<script>
  const btn = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>

<style>
  .nav-link { color: var(--nav-text); transition: color 0.2s; }
  .nav-link:hover { color: var(--nav-hover); }
</style>