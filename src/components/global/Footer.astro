---
const { settings } = Astro.props;
const currentYear = new Date().getFullYear();

const footerBgStart = settings?.footerBg?.hex || 'transparent';
const footerBgEnd = settings?.footerBgEnd?.hex;
const footerOpacity = (settings?.footerOpacity ?? 100) / 100;
const footerTextHex = settings?.footerText?.hex || 'var(--brand-text)';

const footerBackground = footerBgEnd 
  ? `linear-gradient(180deg, ${footerBgStart}, ${footerBgEnd})` 
  : footerBgStart;
---

<footer 
  class="w-full py-20 px-6 md:px-12 border-t border-white/5 backdrop-blur-sm mt-auto" 
  style={`background: ${footerBackground}; opacity: ${footerOpacity};`}
>
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-start md:items-end gap-8">
    
    <div class="flex flex-col gap-4 text-left">
      <h2 class="text-2xl font-bold font-[family-name:var(--font-heading)] tracking-tighter" style={`color: ${footerTextHex};`}>
        {settings?.title || "Shining Form"}
      </h2>
      <p class="text-[10px] uppercase tracking-[0.3em] font-bold opacity-50" style={`color: ${footerTextHex};`}>
        &copy; {currentYear} All Rights Reserved
      </p>
    </div>
    
    <div class="text-left md:text-right flex flex-col gap-2">
      <p class="text-[10px] uppercase tracking-[0.2em] font-medium opacity-40" style={`color: ${footerTextHex};`}>
        Handcrafted with intention
      </p>
      <a 
        href="https://shiningform.com" 
        target="_blank" 
        rel="noopener noreferrer" 
        class="text-[11px] uppercase tracking-[0.2em] font-black hover:underline transition-all"
        style={`color: ${footerTextHex};`}
      >
        Shining Form Design
      </a>
    </div>

  </div>
</footer>