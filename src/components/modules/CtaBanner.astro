---
import { urlFor } from '../../utils/image'; 

const { 
  heading, 
  subheading, 
  buttonText, 
  buttonLink, 
  backgroundImage,
  headingColor,
  subheadingColor,
  buttonColor,
  buttonTextColor,
  backgroundColor,
  backgroundColorEnd,
  gradientAngle
} = Astro.props;

// Local Override Logic
const start = backgroundColor?.hex;
const end = backgroundColorEnd?.hex;
const angle = gradientAngle || 135;
let localBgStyle = "";

if (start) {
  localBgStyle = end 
    ? `background: linear-gradient(${angle}deg, ${start} 0%, ${end} 100%) !important;` 
    : `background: ${start} !important;`;
}

// Color Fallbacks
const headHex = headingColor?.hex || 'inherit';
const subHex = subheadingColor?.hex || 'inherit';
const btnBgHex = buttonColor?.hex || 'var(--brand-secondary)';
const btnTextHex = buttonTextColor?.hex || '#ffffff';
---

<section 
  class="py-24 relative overflow-hidden"
  style={localBgStyle}
>
    {backgroundImage && (
      <div class="absolute inset-0 opacity-20 pointer-events-none">
        <img src={urlFor(backgroundImage).width(1200).url()} alt="Background" class="w-full h-full object-cover" loading="lazy" />
      </div>
    )}
    
    <div class="relative z-10 max-w-4xl mx-auto text-center px-4">
        {heading && (
          <h2 
            class="text-4xl md:text-5xl font-bold mb-6 font-[family-name:var(--font-heading)]"
            style={`color: ${headHex};`}
          >
            {heading}
          </h2>
        )}
        
        {subheading && (
          <p 
            class="text-xl mb-10 max-w-2xl mx-auto opacity-90 font-[family-name:var(--font-body)]"
            style={`color: ${subHex};`}
          >
            {subheading}
          </p>
        )}
        
        {buttonText && buttonLink && (
          <a 
            href={buttonLink} 
            class="inline-block font-bold py-4 px-8 rounded-full hover:scale-105 active:scale-95 transition-transform shadow-lg font-[family-name:var(--font-body)] uppercase tracking-widest text-sm"
            style={`background-color: ${btnBgHex}; color: ${btnTextHex};`}
          >
            {buttonText}
          </a>
        )}
    </div>
</section>