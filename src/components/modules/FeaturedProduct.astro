---
import { sanityClient } from "sanity:client";
import imageUrlBuilder from "@sanity/image-url";

const { 
  heading, 
  product,
  headingColor,
  backgroundColor,
  backgroundColorEnd,
  gradientAngle,
  cardColor,
  productTitleColor,
  textColor,
  buttonColor,
  buttonTextColor
} = Astro.props;

const builder = imageUrlBuilder(sanityClient);
const urlFor = (source: any) => builder.image(source);

// Standardized Background Logic
const start = backgroundColor?.hex;
const end = backgroundColorEnd?.hex;
const angle = gradientAngle || 135;
let localBgStyle = "";

if (start) {
  localBgStyle = end 
    ? `background: linear-gradient(${angle}deg, ${start} 0%, ${end} 100%) !important;` 
    : `background: ${start} !important;`;
}

// Color Fallbacks
const headHex = headingColor?.hex || 'var(--brand-primary)';
const titleHex = productTitleColor?.hex || 'var(--brand-text)';
const textHex = textColor?.hex || 'var(--brand-text)';
const btnBgHex = buttonColor?.hex || product?.accentColor?.hex || 'var(--brand-secondary)';
const btnTextHex = buttonTextColor?.hex || '#ffffff';
---

<section class="py-24 px-6 md:px-12" style={localBgStyle}>
  {/* Flex container set to justify-start (Left Aligned) */}
  <div class="max-w-7xl mx-auto flex flex-col lg:flex-row items-start justify-start gap-12 lg:gap-20">
    
    {/* Product Image: Content-driven width, anchored left */}
    <div class="w-full lg:w-auto flex-shrink-0 group">
      {product?.productImage && (
        <div class="relative overflow-hidden rounded-2xl shadow-2xl border border-white/10 bg-black/20">
          <img 
            src={urlFor(product.productImage).width(1000).auto('format').url()} 
            alt={product.title || "Featured Product"} 
            class="w-auto h-auto max-w-full md:max-w-[450px] lg:max-w-[550px] max-h-[70vh] object-contain block group-hover:scale-105 transition-transform duration-700"
            loading="lazy"
          />
        </div>
      )}
    </div>
    
    {/* Product Details: Glassmorphism card filling the remaining space */}
    <div 
      class="w-full max-w-3xl bg-white/5 backdrop-blur-xl p-8 md:p-12 rounded-2xl border border-white/10 flex flex-col"
    >
      {heading && (
        <span 
          class="text-[10px] font-bold uppercase tracking-[0.4em] mb-4 font-[family-name:var(--font-body)] opacity-60"
          style={`color: ${headHex};`}
        >
          {heading}
        </span>
      )}
      
      {product?.title && (
        <h2 
          class="text-4xl md:text-6xl font-bold mb-4 font-[family-name:var(--font-heading)] leading-tight tracking-tight"
          style={`color: ${titleHex};`}
        >
          {product.title}
        </h2>
      )}
      
      {product?.price && (
        <p 
          class="text-3xl font-bold mb-8 font-[family-name:var(--font-body)] flex items-center gap-3"
          style={`color: ${btnBgHex};`} 
        >
          <span class="text-sm opacity-50 font-normal uppercase tracking-widest">Starting at</span>
          ${product.price}
        </p>
      )}
      
      {product?.description && (
        <p 
          class="text-lg opacity-80 mb-10 font-[family-name:var(--font-body)] leading-relaxed max-w-2xl"
          style={`color: ${textHex};`}
        >
          {product.description}
        </p>
      )}
      
      {product?.buyLink && (
        <div class="mt-auto pt-6 border-t border-white/10">
          <a 
            href={product.buyLink} 
            class="inline-block py-5 px-12 rounded-full hover:scale-105 active:scale-95 transition-all font-bold shadow-xl uppercase tracking-[0.2em] text-xs"
            style={`background-color: ${btnBgHex}; color: ${btnTextHex};`}
          >
            View Product
          </a>
        </div>
      )}
    </div>
  </div>
</section>