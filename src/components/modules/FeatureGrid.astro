---
import { sanityClient } from "sanity:client";

const { 
  headline, 
  heading, 
  items, 
  features,
  titleColor,
  backgroundColor,
  backgroundColorEnd,
  gradientAngle,
  cardBackgroundColor,
  cardTitleColor,
  cardTextColor,
  badgeColor,
  badgeTextColor
} = Astro.props;

// Standardized Background Logic
const start = backgroundColor?.hex;
const end = backgroundColorEnd?.hex;
const angle = gradientAngle || 135;
let localBgStyle = "";

if (start) {
  localBgStyle = end 
    ? `background: linear-gradient(${angle}deg, ${start} 0%, ${end} 100%) !important;` 
    : `background: ${start} !important;`;
}

// Normalize data
const title = headline || heading;
const gridItems = items || features || [];

// Color Fallbacks
const titleHex = titleColor?.hex || 'var(--brand-text)';
const cardTitleHex = cardTitleColor?.hex || 'var(--brand-text)';
const cardTextHex = cardTextColor?.hex || 'var(--brand-text)';
const badgeBgHex = badgeColor?.hex || 'var(--brand-primary)';
const badgeTextHex = badgeTextColor?.hex || '#ffffff';
---

<section class="py-24 px-6 md:px-12" style={localBgStyle}>
  <div class="max-w-7xl mx-auto">
    
    {/* Header block now left-justified */}
    {title && (
      <div class="mb-16 max-w-3xl">
        <h2 
          class="text-4xl md:text-6xl font-bold font-[family-name:var(--font-heading)] leading-[1.1]"
          style={`color: ${titleHex};`}
        >
          {title}
        </h2>
      </div>
    )}

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {gridItems.map((item: any, index: number) => (
        <div 
          class="bg-white/5 backdrop-blur-xl p-8 rounded-2xl border border-white/10 relative group hover:bg-white/10 transition-all duration-500 flex flex-col h-full"
        >
          {/* Refined Badge Style */}
          <div 
            class="w-10 h-10 flex items-center justify-center rounded-full font-bold text-sm shadow-lg mb-8 border border-white/20 transition-transform group-hover:scale-110 font-[family-name:var(--font-body)]"
            style={`background-color: ${badgeBgHex}; color: ${badgeTextHex};`}
          >
            {index + 1}
          </div>
          
          <h3 
            class="text-2xl font-bold mb-4 font-[family-name:var(--font-heading)] tracking-tight leading-tight"
            style={`color: ${cardTitleHex};`}
          >
            {item.title}
          </h3>
          
          <p 
            class="text-base leading-relaxed font-[family-name:var(--font-body)] opacity-80"
            style={`color: ${cardTextHex};`}
          >
            {item.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>