---
const { 
  headline, 
  heading, 
  items, 
  features,
  titleColor,
  backgroundColor,
  backgroundColorEnd,
  gradientAngle,
  cardBackgroundColor,
  cardTitleColor,
  cardTextColor,
  badgeColor,
  badgeTextColor
} = Astro.props;

// Local Override Logic for the Section Wrapper
const start = backgroundColor?.hex;
const end = backgroundColorEnd?.hex;
const angle = gradientAngle || 135;
let localBgStyle = "";

if (start) {
  localBgStyle = end 
    ? `background: linear-gradient(${angle}deg, ${start} 0%, ${end} 100%) !important;` 
    : `background: ${start} !important;`;
}

// Normalize data
const title = headline || heading;
const gridItems = items || features || [];

// Color Fallbacks
const titleHex = titleColor?.hex || 'var(--brand-text)';
const cardBgHex = cardBackgroundColor?.hex || 'rgba(255, 255, 255, 0.4)';
const cardTitleHex = cardTitleColor?.hex || 'var(--brand-text)';
const cardTextHex = cardTextColor?.hex || 'var(--brand-text)';
const badgeBgHex = badgeColor?.hex || 'var(--brand-primary)';
const badgeTextHex = badgeTextColor?.hex || '#ffffff';
---

<section class="py-24 px-6" style={localBgStyle}>
  <div class="max-w-7xl mx-auto">
    
    {title && (
      <h2 
        class="text-3xl md:text-4xl font-normal text-center mb-16 tracking-tight font-[family-name:var(--font-body)]"
        style={`color: ${titleHex};`}
      >
        {title}
      </h2>
    )}

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      {gridItems.map((item: any, index: number) => (
        <div 
          class="backdrop-blur-md p-8 rounded-2xl shadow-sm border border-[var(--brand-primary)]/10 relative group hover:-translate-y-2 transition-transform duration-300"
          style={`background-color: ${cardBgHex};`}
        >
          <span 
            class="absolute -top-4 -left-4 w-12 h-12 flex items-center justify-center rounded-full font-bold text-xl shadow-md transition-transform group-hover:scale-110 font-[family-name:var(--font-body)]"
            style={`background-color: ${badgeBgHex}; color: ${badgeTextHex};`}
          >
            {index + 1}
          </span>
          
          <h3 
            class="text-2xl font-bold mb-3 font-[family-name:var(--font-heading)]"
            style={`color: ${cardTitleHex};`}
          >
            {item.title}
          </h3>
          
          <p 
            class="opacity-90 leading-relaxed font-[family-name:var(--font-body)]"
            style={`color: ${cardTextHex};`}
          >
            {item.description}
          </p>
        </div>
      ))}
    </div>
    
  </div>
</section>