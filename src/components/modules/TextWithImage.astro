---
import { sanityClient } from "sanity:client";
import imageUrlBuilder from "@sanity/image-url";

const { 
  heading, headingColor, tagline, taglineColor, text, textColor, 
  backgroundColor, backgroundColorEnd, gradientAngle, image, layout 
} = Astro.props;

const builder = imageUrlBuilder(sanityClient);
const urlFor = (source: any) => builder.image(source);

const start = backgroundColor?.hex;
const end = backgroundColorEnd?.hex;
const angle = gradientAngle || 135;

let localBgStyle = "";
if (start) {
  localBgStyle = end 
    ? `background: linear-gradient(${angle}deg, ${start} 0%, ${end} 100%) !important;` 
    : `background: ${start} !important;`;
}

const hColor = headingColor?.hex || 'inherit';
const tColor = taglineColor?.hex || 'inherit';
const bColor = textColor?.hex || 'inherit';
---

<section class="py-24 px-6 md:px-12" style={localBgStyle}>
  {/* Added mx-auto back to center the container while keeping the content left-justified */}
  <div class={`max-w-7xl mx-auto flex flex-col md:flex-row items-start justify-start gap-12 ${layout === 'right' ? 'md:flex-row-reverse' : ''}`}>
    
    {/* Image container: Width auto, no centered alignment. Block is grouped with text. */}
    <div class="w-full md:w-auto flex-shrink-0">
      {image && (
        <img 
          src={urlFor(image).width(1200).url()} 
          alt={heading || "Studio Content"}
          class="w-auto h-auto max-w-full md:max-w-[350px] lg:max-w-[450px] max-h-[65vh] object-contain shadow-2xl rounded-sm block"
          loading="lazy"
        />
      )}
    </div>

    {/* Text container: Fills remaining space, sitting closely to the image. */}
    <div class="w-full flex-grow flex flex-col gap-6 text-left max-w-3xl">
      {tagline && (
        <span class="text-xs uppercase tracking-[0.4em] font-bold" style={`color: ${tColor};`}>
          {tagline}
        </span>
      )}
      {heading && (
        <h2 class="text-4xl md:text-7xl font-bold font-[family-name:var(--font-heading)] leading-[1.1]" style={`color: ${hColor};`}>
          {heading}
        </h2>
      )}
      {text && (
        <p class="text-lg md:text-xl leading-relaxed opacity-90 font-[family-name:var(--font-body)]" style={`color: ${bColor};`}>
          {text}
        </p>
      )}
    </div>
  </div>
</section>