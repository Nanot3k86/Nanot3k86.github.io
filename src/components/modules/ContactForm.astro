---
const { heading, subheading, backgroundColor, backgroundColorEnd, gradientAngle, buttonColor, buttonTextColor, headingColor, subheadingColor } = Astro.props;

const start = backgroundColor?.hex || '#1F705B';
const end = backgroundColorEnd?.hex;
const angle = gradientAngle || 135;
let localBgStyle = end 
  ? `background: linear-gradient(${angle}deg, ${start} 0%, ${end} 100%) !important;` 
  : `background: ${start} !important;`;
---

<section class="py-24 px-6" style={localBgStyle}>
  <div class="max-w-3xl mx-auto bg-white/10 backdrop-blur-xl p-8 md:p-12 rounded-2xl shadow-2xl border border-white/20">
    <div class="text-center mb-10">
      <h2 class="text-4xl font-bold mb-4 font-[family-name:var(--font-heading)]" style={`color: ${headingColor?.hex || '#ffffff'};`}>
        {heading || "Get in Touch"}
      </h2>
      <p class="text-lg opacity-90" style={`color: ${subheadingColor?.hex || '#ffffff'};`}>
        {subheading || "Let's build something incredible together."}
      </p>
    </div>

    <form action="https://api.web3forms.com/submit" method="POST" class="space-y-6">
      <input type="hidden" name="access_key" value={import.meta.env.PUBLIC_WEB3FORMS_KEY}>
      <input type="hidden" name="redirect" value="https://shiningform.com/thanks">
      <input type="hidden" name="subject" value="New Website Inquiry">
      <input type="checkbox" name="botcheck" class="hidden" style="display: none;">

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-white text-sm font-bold mb-2 uppercase tracking-widest">Name</label>
          <input type="text" name="name" required class="w-full bg-white/5 border border-white/20 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-white/50 transition-colors" placeholder="Your Name" />
        </div>
        <div>
          <label class="block text-white text-sm font-bold mb-2 uppercase tracking-widest">Email</label>
          <input type="email" name="email" required class="w-full bg-white/5 border border-white/20 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-white/50 transition-colors" placeholder="Email Address" />
        </div>
      </div>

      <div>
        <label class="block text-white text-sm font-bold mb-2 uppercase tracking-widest">Message</label>
        <textarea name="message" rows="5" required class="w-full bg-white/5 border border-white/20 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-white/50 transition-colors" placeholder="How can I help you?"></textarea>
      </div>

      <button 
        type="submit" 
        class="w-full py-4 rounded-lg font-bold uppercase tracking-[0.2em] shadow-lg hover:scale-[1.02] active:scale-[0.98] transition-all"
        style={`background-color: ${buttonColor?.hex || '#ffffff'}; color: ${buttonTextColor?.hex || '#000000'};`}
      >
        Send Message
      </button>
    </form>
  </div>
</section>