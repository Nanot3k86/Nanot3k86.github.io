---
import { sanityClient } from "sanity:client";
import imageUrlBuilder from "@sanity/image-url";

const { headline, subheading, headlineColor, subheadingColor, backgroundColor, backgroundColorEnd, gradientAngle, items } = Astro.props;
const builder = imageUrlBuilder(sanityClient);
const urlFor = (source: any) => builder.image(source);

// DEBUG LOG: This will print the exact data Astro is receiving to your VS Code Terminal
console.log("--- GALLERY MODULE ITEMS ---");
console.dir(items, { depth: null });

const start = backgroundColor?.hex;
const end = backgroundColorEnd?.hex;
const angle = gradientAngle || 135;
let localBgStyle = "";

if (start) {
  localBgStyle = end 
    ? `background: linear-gradient(${angle}deg, ${start} 0%, ${end} 100%) !important;` 
    : `background: ${start} !important;`;
}
---

<section class="py-24 px-6" style={localBgStyle}>
  <div class="max-w-7xl mx-auto">
    
    {(headline || subheading) && (
      <div class="mb-16 max-w-3xl">
        {headline && (
          <h2 class="text-4xl md:text-5xl font-bold mb-4 font-[family-name:var(--font-heading)]" style={`color: ${headlineColor?.hex || '#ffffff'};`}>
            {headline}
          </h2>
        )}
        {subheading && (
          <p class="text-lg opacity-90 max-w-2xl" style={`color: ${subheadingColor?.hex || '#ffffff'};`}>
            {subheading}
          </p>
        )}
      </div>
    )}

    <div class="columns-2 sm:columns-4 lg:columns-6 gap-4 space-y-4">
      {items && items.length > 0 ? items.map((item: any) => {
        const type = item.mediaType || 'image';
        const altText = item.alt || "Gallery Media";
        const caption = item.caption || '';
        
        const thumbUrl = item.image ? urlFor(item.image).width(400).auto('format').url() : '';
        const fullImgUrl = item.image ? urlFor(item.image).url() : ''; 
        const videoUrl = item.videoUrl || '';
        const audioUrl = item.audioUrl || '';

        return (
          <div class="break-inside-avoid relative group cursor-pointer">
            <button 
              class="gallery-trigger w-full overflow-hidden rounded-xl shadow-lg hover:shadow-2xl transition-all bg-black/10 relative block border border-white/10"
              data-type={type}
              data-img={fullImgUrl}
              data-video={videoUrl}
              data-audio={audioUrl}
              data-alt={altText}
              data-caption={caption}
            >
              {thumbUrl ? (
                <img 
                  src={thumbUrl} 
                  alt={altText}
                  class="w-full h-auto object-cover group-hover:scale-105 transition-transform duration-700 block"
                  loading="lazy"
                />
              ) : (
                <div class="w-full h-32 bg-black/20 flex items-center justify-center text-white/50 font-bold uppercase tracking-widest text-[10px] text-center p-2">No Cover Art</div>
              )}

              <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-4 z-10 pointer-events-none">
                {caption && (
                  <p class="text-white text-xs font-bold tracking-wide translate-y-2 group-hover:translate-y-0 transition-transform duration-300 text-left">
                    {caption}
                  </p>
                )}
              </div>

              {(type === 'video' || type === 'audio') && (
                <div class="absolute inset-0 flex items-center justify-center bg-black/30 group-hover:bg-black/10 transition-colors z-0 pointer-events-none">
                  <div class="w-10 h-10 rounded-full bg-white/90 flex items-center justify-center shadow-lg backdrop-blur-sm group-hover:scale-110 transition-transform">
                    <svg class="w-5 h-5 text-[var(--brand-primary)] ml-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                  </div>
                </div>
              )}
            </button>
          </div>
        );
      }) : (
        <div class="text-center py-20 opacity-50 w-full col-span-full text-white">No items found in this gallery.</div>
      )}
    </div>
  </div>

  <div 
    id="gallery-lightbox" 
    class="fixed left-0 w-full z-[150] bg-black/95 hidden flex-col items-center justify-center p-4 md:p-12 transition-all backdrop-blur-md"
    style="top: var(--nav-height); height: calc(100vh - var(--nav-height));"
  >
    <button id="close-lightbox" class="absolute top-6 right-8 text-white text-4xl z-[160] hover:scale-110 transition-transform" aria-label="Close">&times;</button>
    <div id="lightbox-content" class="relative w-full h-full flex items-center justify-center max-w-6xl mx-auto">
    </div>
  </div>
</section>

<script>
  const triggers = document.querySelectorAll('.gallery-trigger');
  const lightbox = document.getElementById('gallery-lightbox');
  const lightboxContent = document.getElementById('lightbox-content');
  const closeBtn = document.getElementById('close-lightbox');

  triggers.forEach(trigger => {
    trigger.addEventListener('click', () => {
      if (!lightbox || !lightboxContent) return;
      
      const type = trigger.getAttribute('data-type');
      const alt = trigger.getAttribute('data-alt');
      const imgSrc = trigger.getAttribute('data-img');
      const videoSrc = trigger.getAttribute('data-video');
      const audioSrc = trigger.getAttribute('data-audio');
      const caption = trigger.getAttribute('data-caption');

      lightboxContent.innerHTML = '';
      const captionHTML = caption ? `<p class="text-white text-lg font-bold mt-6 tracking-wide text-center animate-fade-in">${caption}</p>` : '';

      if (type === 'image' && imgSrc) {
        lightboxContent.innerHTML = `
          <div class="flex flex-col items-center justify-center w-full h-full">
            <img src="${imgSrc}" alt="${alt}" class="max-w-full max-h-[75vh] object-contain shadow-2xl animate-fade-in rounded-lg" />
            ${captionHTML}
          </div>
        `;
      } 
      else if (type === 'video' && videoSrc) {
        lightboxContent.innerHTML = `
          <div class="flex flex-col items-center w-full max-w-5xl">
            <div class="w-full aspect-video shadow-2xl animate-fade-in bg-black rounded-lg overflow-hidden">
              <iframe src="${videoSrc}" class="w-full h-full" frameborder="0" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen></iframe>
            </div>
            ${captionHTML}
          </div>
        `;
      } 
      else if (type === 'audio' && audioSrc) {
        lightboxContent.innerHTML = `
          <div class="flex flex-col items-center justify-center gap-6 w-full max-w-md bg-white/10 p-10 rounded-2xl backdrop-blur-xl shadow-2xl animate-fade-in border border-white/20">
            ${imgSrc ? `<img src="${imgSrc}" class="w-48 h-48 object-cover rounded-full shadow-lg border-4 border-white/20" />` : ''}
            <h3 class="text-white text-2xl font-bold text-center font-[family-name:var(--font-heading)]">${alt}</h3>
            <audio controls autoplay class="w-full outline-none">
              <source src="${audioSrc}" type="audio/mpeg">
              <source src="${audioSrc}" type="audio/wav">
            </audio>
            ${captionHTML}
          </div>
        `;
      }

      lightbox.classList.remove('hidden');
      lightbox.classList.add('flex');
      document.body.style.overflow = 'hidden';
    });
  });

  const close = () => {
    if (lightbox && lightboxContent) {
      lightbox.classList.add('hidden');
      lightbox.classList.remove('flex');
      document.body.style.overflow = 'auto';
      lightboxContent.innerHTML = '';
    }
  };

  closeBtn?.addEventListener('click', close);
  lightbox?.addEventListener('click', (e) => { 
    if(e.target === lightbox || e.target === lightboxContent) close(); 
  });
</script>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: scale(0.95); }
    to { opacity: 1; transform: scale(1); }
  }
  .animate-fade-in { animation: fadeIn 0.3s ease-out forwards; }
</style>