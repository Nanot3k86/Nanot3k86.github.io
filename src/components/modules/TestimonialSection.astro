---
import { urlFor } from '../../utils/image';

const { 
  heading, 
  testimonials, 
  headingColor, 
  backgroundColor,
  backgroundColorEnd,
  gradientAngle
} = Astro.props;

// Local Override Logic
const start = backgroundColor?.hex;
const end = backgroundColorEnd?.hex;
const angle = gradientAngle || 135;
let localBgStyle = "";

if (start) {
  localBgStyle = end 
    ? `background: linear-gradient(${angle}deg, ${start} 0%, ${end} 100%) !important;` 
    : `background: ${start} !important;`;
}

// Section Fallbacks
const headHex = headingColor?.hex || 'var(--brand-text)';
---

<section class="py-20" style={localBgStyle}>
  <div class="max-w-7xl mx-auto px-4 md:px-8">
    {heading && (
      <h2 
        class="text-4xl md:text-5xl font-bold text-center mb-16 font-[family-name:var(--font-heading)]"
        style={`color: ${headHex};`}
      >
        {heading}
      </h2>
    )}
    
    <div class="grid md:grid-cols-3 gap-8">
      {testimonials?.map((t: any) => {
        // Individual item fallbacks
        const quoteHex = t.quoteColor?.hex || 'var(--brand-text)';
        const authorHex = t.authorColor?.hex || 'var(--brand-text)';
        const roleHex = t.roleColor?.hex || 'var(--brand-text)';

        return (
          <div class="bg-white/40 backdrop-blur-md p-8 rounded-3xl shadow-sm border border-[var(--brand-primary)]/10 flex flex-col h-full hover:shadow-lg transition-all duration-300">
            <p 
              class="italic mb-8 flex-grow font-[family-name:var(--font-body)] text-lg leading-relaxed opacity-90"
              style={`color: ${quoteHex};`}
            >
              "{t.quote}"
            </p>
            <div class="flex items-center gap-4 border-t border-[var(--brand-primary)]/10 pt-6">
              {t.photo && (
                <img 
                  src={urlFor(t.photo).width(100).height(100).url()} 
                  alt={t.author || "Testimonial Author"} 
                  class="w-14 h-14 rounded-full object-cover shadow-sm border-2 border-[var(--brand-primary)]/20"
                  loading="lazy"
                />
              )}
              <div>
                <p 
                  class="font-bold font-[family-name:var(--font-heading)] text-xl"
                  style={`color: ${authorHex};`}
                >
                  {t.author}
                </p>
                <p 
                  class="text-sm opacity-70 font-[family-name:var(--font-body)] tracking-wide uppercase"
                  style={`color: ${roleHex};`}
                >
                  {t.role}
                </p>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>