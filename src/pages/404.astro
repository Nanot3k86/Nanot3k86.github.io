---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - Page Not Found">
  <section class="min-h-[70vh] flex items-center justify-center px-6 py-24 text-center">
    <div class="max-w-2xl mx-auto">
      <h1 
        class="text-9xl md:text-[12rem] font-black opacity-10 leading-none select-none font-[family-name:var(--font-heading)]"
        style="color: var(--brand-primary);"
      >
        404
      </h1>

      <div class="relative -mt-12 md:-mt-20">
        <h2 class="text-3xl md:text-5xl font-bold mb-6 font-[family-name:var(--font-heading)] uppercase tracking-tight">
          Lost in the void?
        </h2>
        
        <p class="text-lg md:text-xl mb-10 opacity-80 max-w-md mx-auto font-[family-name:var(--font-body)]">
          The page you're looking for has moved or no longer exists. Let's get you back to the studio.
        </p>

        <a 
          href="/" 
          class="inline-block px-10 py-4 font-bold uppercase tracking-widest text-sm transition-all hover:scale-105 active:scale-95 shadow-xl font-[family-name:var(--font-body)]"
          style="background-color: var(--brand-primary); color: white;"
        >
          Back to Home
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Optional: Add a subtle floating animation to the 404 text */
  h1 {
    animation: float 6s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-20px); }
  }
</style>