---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - Page Not Found">
  <section class="min-h-[80vh] flex items-center px-6 md:px-12 py-24 relative overflow-hidden">
    
    {/* Massive Background Text - Anchored Left */}
    <h1 
      class="absolute left-[-5%] top-[10%] text-[20rem] md:text-[35rem] font-black opacity-[0.03] leading-none select-none font-[family-name:var(--font-heading)] pointer-events-none"
      style="color: var(--brand-primary);"
    >
      404
    </h1>

    <div class="max-w-7xl mx-auto w-full relative z-10">
      <div class="max-w-3xl text-left">
        
        <h2 class="text-5xl md:text-8xl font-bold mb-8 font-[family-name:var(--font-heading)] leading-tight tracking-tight">
          Lost in <br/> the void.
        </h2>
        
        <p class="text-xl md:text-2xl mb-12 opacity-70 max-w-xl font-[family-name:var(--font-body)] leading-relaxed">
          The page you're looking for has moved or no longer exists. Let's get you back to the studio to start fresh.
        </p>

        <a 
          href="/" 
          class="inline-block px-12 py-5 rounded-full font-bold uppercase tracking-[0.2em] text-xs transition-all hover:scale-105 active:scale-95 shadow-2xl font-[family-name:var(--font-body)]"
          style="background-color: var(--brand-primary); color: white;"
        >
          Return to Studio
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Updated floating animation for the massive background text */
  h1 {
    animation: float 10s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(20px, -30px); }
  }
</style>